# Copie este arquivo para ".env" e preencha com suas chaves.

# TMDB — crie uma conta em https://www.themoviedb.org e gere a credencial em
# Configurações > API. Aceita tanto o "Token de Leitura da API" (v4, começa
# com "eyJ") quanto a "Chave da API" (v3, 32 caracteres).
EXPO_PUBLIC_TMDB_API_KEY=

# Supabase — crie um projeto gratuito em https://supabase.com/dashboard.
# Os dois valores ficam em Project Settings > API.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat (assinatura premium) — chaves públicas de SDK por plataforma,
# em Project Settings > API Keys no painel (https://app.revenuecat.com).
# Sem a chave o app funciona normalmente, só esconde a oferta premium.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# AppLovin MAX (anúncios para não-premium) — em https://dash.applovin.com.
# SDK key em Account > Keys; ad units de banner em MAX > Ad Units.
# Sem esses valores o app funciona normalmente, só não exibe anúncios.
EXPO_PUBLIC_APPLOVIN_SDK_KEY=
EXPO_PUBLIC_APPLOVIN_BANNER_IOS=
EXPO_PUBLIC_APPLOVIN_BANNER_ANDROID=
